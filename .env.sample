# --- メール送信まで行う場合の最低限の例（新規 .env の目安）---
# GOOGLE_API_KEY="あなたのAPIキー"
# TRUTH_ASSESSMENT_GROUNDING=1
# TO_EMAIL="あなたのメルアド"
# GMAIL_USER="送信元のメルアド"
# GMAIL_APP_PASSWORD="送信元のGmailのアプリパスワード"   # アプリパスワード(16文字)。通常ログインパスワードではない
# 宛先は MAIL_TO でも可。メール不要なら TO_EMAIL/MAIL_TO を空にして run_pipeline.sh → 自動 --skip-email

# Google Gemini API キー
# 単一: GOOGLE_API_KEY のみ
# 複数: GOOGLE_API_KEY_1, GOOGLE_API_KEY_2, …（数字は m03_api_key_manager が走査）
# キー本数分ローテーションするとレート制限回避に有効
GOOGLE_API_KEY=""
# GOOGLE_API_KEY_1=""
# GOOGLE_API_KEY_2=""
# GOOGLE_API_KEY_3=""
# 必要に応じて GOOGLE_API_KEY_4 … なども可（a03 の直参照フォールバックは _6 まで）


# モデル列: a03 は m03_gemini_model_fallback.get_gemini_model_fallback_chain がある場合のみそれを使う（未同梱時は a03 内の既定フォールバック列）。

# 真実度の検索グラウンディング（オプション）
# 0=オフ、1=オン（未設定もオン扱い）。要約前の全文に対して、公開情報を検索して信頼性の目安を採点する。
TRUTH_ASSESSMENT_GROUNDING=1

# 送信先（いずれか。run_pipeline.sh は MAIL_TO / TO_EMAIL の有無で --skip-email を切り替え）
# MAIL_TO=""
TO_EMAIL=""

# Gmail SMTP（a04。未設定ならメール送信スキップ）
GMAIL_USER=""
GMAIL_APP_PASSWORD=""
# 上記は「アプリ パスワード」（16文字）。通常の Gmail ログインパスワードではない。
# ブラウザのアドレスバーに次のURLを入力して開きます。
# https://myaccount.google.com/apppasswords
# 2段階認証が有効なアカウントなら、ここで「アプリ パスワード」のページが開きます。
# 開いたら「アプリを選択」で「メール」などを選び、「生成」で16文字のパスワードを発行できます。

# a04: 要約 API 失敗時に summary.txt に入れる文面（未設定はコード内の既定文）
# SUMMARY_UNAVAILABLE_BODY="【要約の自動生成は行えませんでした】\n..."

# a04: メール本文（要約）の最大文字数。正の整数のとき超過分を省略
# MAIL_BODY_SUMMARY_MAX_CHARS=8000
